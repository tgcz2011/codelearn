{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeLearn",
  "version": "0.1.0",
  "identifier": "com.codelearn.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build"
  },
  "app": {
    "windows": [
      {
        "title": "CodeLearn",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri: asset:",
        "connect-src": "'self' ipc: http://ipc.localhost https://*.supabase.co https://api.onlinecompiler.io",
        "img-src": "'self' asset: data: https:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  }
}
