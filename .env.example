# ====================================================
# CodeLearn 根目录环境变量示例
# ====================================================
# 说明：本项目是 monorepo。
#   - 前端（web/）环境变量在 web/.env.example，复制为 web/.env 使用
#   - 本文件仅列出 go-runner/ 远程服务的运行时环境变量（服务端，非 VITE_ 前缀）
#
# 前端开发请用：
#   cp web/.env.example web/.env
# ====================================================

# --- go-runner 远程代码执行服务（服务端运行时变量）---
# 仅在运行 go-runner 服务时使用，详见 go-runner/README.md
# 这些变量由 go-runner/main.go 读取，与前端 VITE_ 变量无关

# 监听端口（Fly.io / Render 会自动注入 PORT）
# PORT=8080

# 最大并发执行数
# MAX_CONCURRENT=10

# CORS 白名单，逗号分隔，如 https://a.com,https://b.com（空 = 允许所有源）
# ALLOWED_ORIGINS=

# Linux 子进程内存上限（MB），0 = 关闭；注意 Go 运行时虚拟内存特性，生产建议用 Docker --memory
# MEM_LIMIT_MB=0
